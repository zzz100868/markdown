{
  "name": "markdown-online-editor",
  "version": "4.0.0",
  "author": "nicejade",
  "private": true,
  "type": "module",
  "description": "Arya，是一款基于 Vue3、Vite、Vditor 构建的在线 Markdown 编辑器；轻量且强大。",
  "scripts": {
    "prestart": "node -e \"import('fs').then(({cpSync,mkdirSync,rmSync,existsSync})=>{mkdirSync('public/vendor',{recursive:true});cpSync('node_modules/@turbodocx/html-to-docx/dist/html-to-docx.browser.js','public/vendor/html-to-docx.browser.js');if(existsSync('public/vditor'))rmSync('public/vditor',{recursive:true});mkdirSync('public/vditor/dist',{recursive:true});cpSync('node_modules/vditor/dist','public/vditor/dist',{recursive:true})})\"",
    "start": "npm run prestart && vite",
    "serve": "vite",
    "prebuild": "node -e \"import('fs').then(({cpSync,mkdirSync,rmSync,existsSync})=>{mkdirSync('public/vendor',{recursive:true});cpSync('node_modules/@turbodocx/html-to-docx/dist/html-to-docx.browser.js','public/vendor/html-to-docx.browser.js');if(existsSync('public/vditor'))rmSync('public/vditor',{recursive:true});mkdirSync('public/vditor/dist',{recursive:true});cpSync('node_modules/vditor/dist','public/vditor/dist',{recursive:true})})\" ",
    "build": "vite build",
    "preview": "vite preview",
    "watcher": "onchange \"src/**/**/*.{js,css,scss,vue}\" -- prettier --write {{changed}}",
    "prettier": "prettier --write \"src/**/**/*.{js,css,scss,vue}\"",
    "format-code": "prettier --write \"src/**/*.{js,vue,css,scss}\"",
    "deploy": "bash ./commands/deploy.sh",
    "release": "pm2 start ecosystem.config.js --env production",
    "analyz": "NODE_ENV=production npm_config_report=true npm run build"
  },
  "dependencies": {
    "@turbodocx/html-to-docx": "^1.20.1",
    "autoprefixer": "^10.5.0",
    "canvg": "^2.0.0",
    "element-plus": "^2.9.7",
    "hint.css": "^2.6.0",
    "html2canvas": "1.3.2",
    "html2pdf.js": "^0.9.1",
    "lodash.assign": "^4.2.0",
    "lodash.clonedeep": "^4.5.0",
    "mitt": "^3.0.1",
    "pinia": "^3.0.4",
    "postcss": "^8.5.10",
    "register-service-worker": "^1.0.0",
    "reveal.js": "^3.8.0",
    "vditor": "^3.11.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "fast-glob": "^3.3.3",
    "less": "^4.3.0",
    "onchange": "^7.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.19",
    "vite": "^6.2.6",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ]
}
